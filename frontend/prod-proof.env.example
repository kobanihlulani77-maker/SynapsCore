# Live hosted proof targets.
PLAYWRIGHT_BASE_URL=https://synapscore-frontend-3.onrender.com
PLAYWRIGHT_API_BASE_URL=https://synapscore-3.onrender.com

# Real proof tenant created through /api/access/tenants, not seed/demo data.
PLAYWRIGHT_TENANT_CODE=<hosted-proof-tenant-code>

# Usernames must contain only letters, digits, dots, underscores, and hyphens.
# Tenant admin: tenant bootstrap admin / access administrator.
PLAYWRIGHT_TENANT_ADMIN_USERNAME=<tenant-admin-username>
PLAYWRIGHT_TENANT_ADMIN_PASSWORD=<tenant-admin-password>

# Planner/operator: ordinary workspace operator used to prove non-admin access boundaries.
PLAYWRIGHT_PLANNER_USERNAME=<planner-operator-username>
PLAYWRIGHT_PLANNER_PASSWORD=<planner-operator-password>

# Integration admin: connector/replay operator used to prove integration and recovery flows.
PLAYWRIGHT_INTEGRATION_ADMIN_USERNAME=<integration-admin-username>
PLAYWRIGHT_INTEGRATION_ADMIN_PASSWORD=<integration-admin-password>
